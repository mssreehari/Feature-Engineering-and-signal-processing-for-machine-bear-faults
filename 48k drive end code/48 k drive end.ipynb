import streamlit as st
import matplotlib.pyplot as plt
import pandas as pd
from cwru_model import run_cwru_model

# --------------------------------------------------
# Page Configuration
# --------------------------------------------------
st.set_page_config(page_title="CWRU Dashboard", layout="wide")

BASE_DIR = "/content/drive/MyDrive/pdm_data/cwru48"

st.markdown(
    "<h1 style='text-align:center;'>🔧 CWRU Bearing Fault Diagnosis Dashboard</h1>",
    unsafe_allow_html=True
)

# --------------------------------------------------
# Sidebar Settings
# --------------------------------------------------
st.sidebar.header("⚙️ Experiment Settings")

window_size = st.sidebar.selectbox(
    "Window Size (L)",
    [1024, 2048, 4096],
    index=1
)

stride = st.sidebar.selectbox(
    "Stride (S)",
    [512, 1024, 2048],
    index=1
)

# --------------------------------------------------
# Initialize History (VERY IMPORTANT)
# --------------------------------------------------
if "history" not in st.session_state:
    st.session_state.history = []

# --------------------------------------------------
# Run Model Button
# --------------------------------------------------
if st.button("🚀 Run Model"):

    with st.spinner("Running model… ⏳"):
        clf, scaler, f1_safe, latency_ms, y_pred = run_cwru_model(
            BASE_DIR,
            window_size,
            stride
        )

    st.success("Model evaluation completed ✅")

    # Save to history
    st.session_state.history.append({
        "Window Size": window_size,
        "Stride": stride,
        "Safe F1": f1_safe,
        "Latency (ms)": latency_ms
    })

    # ---------------- Metrics ----------------
    col1, col2, col3 = st.columns(3)

    col1.metric("Safe F1", f"{f1_safe:.3f}")
    col2.metric("Latency (ms)", f"{latency_ms:.2f}")

    lir = 0.918 / f1_safe
    col3.metric("LIR", f"{lir:.2f}")

     # ---------------- Leaky vs Safe ----------------
    fig, ax = plt.subplots(figsize=(5, 4))
    ax.plot(["Leaky F1", "Safe F1"], [0.918, f1_safe], marker="o", linewidth=2)
    ax.set_ylim(0, 1)
    ax.set_ylabel("Macro F1-score")
    ax.set_title("Leaky vs Safe Evaluation")
    ax.grid(alpha=0.3)
    st.pyplot(fig)


    # ---------------- Fault Type Prediction ----------------
    import numpy as np

    dominant_class = np.bincount(y_pred).argmax()

    label_map = {
        0: "🟢 Healthy",
        1: "🔴 Inner Race Fault",
        2: "🔴 Outer Race Fault",
        3: "🔴 Ball Fault"
    }

    st.divider()
    st.markdown("### 🔍 Dominant Predicted Machine Condition")
    st.success(label_map.get(dominant_class, "Unknown Fault Type"))

    # ---------------- Interpretation ----------------
    st.divider()
    st.markdown("### 🧠 System Interpretation")

    if f1_safe >= 0.8:
        st.success("🟢 The model is highly reliable.")
    elif f1_safe >= 0.6:
        st.info("🟡 The model has moderate reliability.")
    elif f1_safe >= 0.4:
        st.warning("🟠 The model reliability is low.")
    else:
        st.error("🔴 The model is not reliable enough for deployment.")

    if lir > 1:
        st.warning("⚠ Significant leakage effect detected.")
    else:
        st.success("🟢 No significant leakage detected.")

# --------------------------------------------------
# Experiment History Table (Always Visible After Run)
# --------------------------------------------------
st.divider()
st.markdown("### 📊 Experiment History")

if len(st.session_state.history) > 0:

    df = pd.DataFrame(st.session_state.history)
    st.dataframe(df)

    # Show trends if 2+ runs
    if len(st.session_state.history) >= 2:
        st.markdown("### 📈 Trends")

        colA, colB = st.columns(2)

        with colA:
            f1_df = df.groupby("Window Size")["Safe F1"].mean()
            st.line_chart(f1_df)

        with colB:
            lat_df = df.groupby("Window Size")["Latency (ms)"].mean()
            st.line_chart(lat_df)

else:
    st.info("Run the model to generate comparison data.")


