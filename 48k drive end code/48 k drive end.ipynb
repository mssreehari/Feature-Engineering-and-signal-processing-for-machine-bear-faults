# -------- Latency --------
def measure_latency(clf, scaler, X_example, n_repeats=500):
    t0 = time.time()
    for _ in range(n_repeats):
        clf.predict(scaler.transform(X_example))
    return ((time.time() - t0) / n_repeats) * 1000  # ms

latency_ms = measure_latency(clf, scaler, X_test[:64])

