def run_cwru_model():
    """
    This function runs your EXISTING ML pipeline
    and returns ONLY the final numbers needed for the dashboard
    """

    clf = RandomForestClassifier(
        n_estimators=200,
        random_state=42,
        n_jobs=-1
    )
    clf.fit(X_train_n, y_train)

    # ---------- SAFE F1 ----------
    y_pred = clf.predict(X_test_n)
    f1_safe = f1_score(y_test, y_pred, average="macro")

    # ---------- LATENCY ----------
    latency_ms = measure_latency(clf, scaler, X_test[:64])

    return f1_safe, latency_ms


%%writefile cwru_model.py
import os
import time
import numpy as np
from numpy import fft
from scipy.io import loadmat
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import f1_score

# ---------- helper functions (from your notebook) ----------

def make_windows(signal_1d, L, S):
    windows = []
    for start in range(0, len(signal_1d) - L + 1, S):
        windows.append(signal_1d[start:start+L])
    return np.array(windows)

def time_features(x):
    rms = np.sqrt(np.mean(x**2))
    var = np.var(x)
    ptp = np.ptp(x)
    return np.array([rms, var, ptp])

def extract_features(signal, L, S):
    windows = make_windows(signal, L, S)
    return np.array([time_features(w) for w in windows])

# ---------- MAIN function Streamlit will call ----------

def run_cwru_model(BASE_DIR, L=2048, S=1024):
    X, y = [], []

    for fname in os.listdir(BASE_DIR):
        if not fname.endswith(".mat"):
            continue

        label = int(fname.split("_")[-1].replace(".mat", ""))
        mat = loadmat(os.path.join(BASE_DIR, fname))

        key = [k for k in mat if k.endswith("_DE_time")][0]
        signal = mat[key].flatten()

        feats = extract_features(signal, L, S)

        X.append(feats)
        y.extend([label] * len(feats))

    X = np.vstack(X)
    y = np.array(y)

    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=0.2, stratify=y, random_state=42
    )

    scaler = StandardScaler()
    X_train_n = scaler.fit_transform(X_train)
    X_test_n = scaler.transform(X_test)

    clf = RandomForestClassifier(n_estimators=200, random_state=42, n_jobs=-1)
    clf.fit(X_train_n, y_train)

    f1_safe = f1_score(y_test, clf.predict(X_test_n), average="macro")

    # latency
    t0 = time.time()
    for _ in range(100):
        clf.predict(X_test_n[:64])
    latency_ms = (time.time() - t0) / 100 * 1000

    y_pred = clf.predict(X_test_n)

    return clf, scaler, f1_safe, latency_ms, y_pred

