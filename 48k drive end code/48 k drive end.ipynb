3. Represent the data as “runs”
4. We keep this generic so you can adapt to your file names.

def load_cwru_runs(base_dir):
    runs = []

    for fname in os.listdir(base_dir):
        if not fname.lower().endswith(".mat"):
            continue

        # label from filename: xxx_<label>.mat
        try:
            label = int(fname.split("_")[-1].replace(".mat", ""))
        except:
            continue

        mat = loadmat(os.path.join(base_dir, fname))

        # get vibration signal
        keys = [k for k in mat.keys() if k.endswith("_DE_time") or k.endswith("_FE_time")]
        if len(keys) == 0:
            continue

        signal = mat[keys[0]].flatten().astype(np.float32)

        runs.append({
            "run_id": fname,
            "signal": signal,
            "label": label
        })

    return runs


4. Safe split-by-run vs leaky split

def split_by_run(runs, test_size=0.2, val_size=0.1, random_state=42):
    run_ids = np.arange(len(runs))
    labels = np.array([r["label"] for r in runs])

    train_ids, temp_ids, _, _ = train_test_split(
        run_ids, labels,
        test_size=test_size + val_size,
        stratify=labels,
        random_state=random_state
    )

    val_ratio = val_size / (test_size + val_size)

    val_ids, test_ids, _, _ = train_test_split(
        temp_ids, labels[temp_ids],
        test_size=1 - val_ratio,
        stratify=labels[temp_ids],
        random_state=random_state
    )

    return train_ids, val_ids, test_ids


5. Windowing + simple features
6. We implement one window/stride first (later you can loop over several).

def make_windows(signal_1d, L, S):
    """Return list of windows from one long 1D signal."""
    windows = []
    n = len(signal_1d)
    for start in range(0, n - L + 1, S):
        windows.append(signal_1d[start:start+L])
    return np.stack(windows) if windows else np.empty((0, L))

def time_features(win):

    """Return simple time-domain feature vector for one window."""
    x = win
    rms = np.sqrt(np.mean(x**2))
    var = np.var(x)
    ptp = np.ptp(x)
    skew = ((x - x.mean())**3).mean() / (np.std(x)**3 + 1e-8)
    kurt = ((x - x.mean())**4).mean() / (np.var(x)**2 + 1e-8)
    crest = np.max(np.abs(x)) / (rms + 1e-8)
    impulse = np.max(np.abs(x)) / (np.mean(np.abs(x)) + 1e-8)
    margin = np.max(np.abs(x)) / (np.mean(np.sqrt(np.abs(x)))**2 + 1e-8)
    return np.array([rms, var, ptp, skew, kurt, crest, impulse, margin], dtype=np.float32)

def freq_band_energies(win, fs, bands):
    """Compute energy in given frequency bands."""
    X = np.abs(fft.rfft(win))
    freqs = fft.rfftfreq(len(win), d=1.0/fs)
    energies = []
    for f_low, f_high in bands:
        mask = (freqs >= f_low) & (freqs < f_high)
        energies.append(np.sum(X[mask]**2))
    return np.array(energies, dtype=np.float32)

def extract_features_from_window(win, fs, bands):
    tfeat = time_features(win)
    ffeat = freq_band_energies(win, fs, bands)
    return np.concatenate([tfeat, ffeat])

def build_dataset(runs, run_ids, L, S, fs, bands):
    X_list, y_list, meta_run = [], [], []
    for idx in run_ids:
        r = runs[idx]
        ws = make_windows(r['signal'], L, S)
        for w in ws:
            feat = extract_features_from_window(w, fs, bands)
            X_list.append(feat)
            y_list.append(r['label'])
            meta_run.append(idx)  # store which run this window came from
    X = np.vstack(X_list)
    y = np.array(y_list)
    meta_run = np.array(meta_run)
    return X, y, meta_run


